{
  "name": "terminal-mindmap",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:server": "pnpm --filter @mindmap/server dev",
    "dev:client": "pnpm --filter @mindmap/client dev",
    "build": "pnpm --filter @mindmap/shared build && pnpm -r --parallel build",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "node-pty",
      "esbuild"
    ]
  }
}